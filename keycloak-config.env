# ============================================================
# keycloak-config.env
#
# Central configuration for the Keycloak on OKD deployment.
# Edit this file before running install-keycloak-okd.sh.
#
# Usage:
#   1. Edit the values below for your environment
#   2. Run: ./install-keycloak-okd.sh
# ============================================================


# ── Namespace ───────────────────────────────────────────────
# Kubernetes namespace all Keycloak resources are deployed into.
KEYCLOAK_NAMESPACE=keycloak


# ── Operator ────────────────────────────────────────────────
# OLM channel for the community Keycloak Operator.
OPERATOR_CHANNEL=fast

# OLM install plan approval: Manual or Automatic.
# Manual is strongly recommended — prevents unintended upgrades
# that may run irreversible database migrations.
OPERATOR_INSTALL_APPROVAL=Manual


# ── PostgreSQL ───────────────────────────────────────────────
# Database credentials. Change before deploying to production.
DB_USERNAME=keycloak
DB_PASSWORD=changeme_use_a_strong_password

DB_NAME=keycloak
DB_IMAGE=postgres:15

# Run 'oc get storageclass' to list available classes.
DB_STORAGE_CLASS=nfs-storage
DB_STORAGE_SIZE=10Gi

# ReadWriteMany for NFS, ReadWriteOnce for block storage.
DB_ACCESS_MODE=ReadWriteMany

DB_CPU_REQUEST=250m
DB_CPU_LIMIT=500m
DB_MEMORY_REQUEST=256Mi
DB_MEMORY_LIMIT=512Mi


# ── Keycloak instance ────────────────────────────────────────
# Number of replicas. Use 1 for dev, 2+ for production HA.
KC_INSTANCES=1

KC_CPU_REQUEST=500m
KC_CPU_LIMIT=2
KC_MEMORY_REQUEST=1Gi
KC_MEMORY_LIMIT=2Gi


# ── Hostname and TLS ─────────────────────────────────────────
#
# KC_HOSTNAME_MODE controls how the Keycloak URL and TLS are configured.
#
#   auto      OKD auto-assigns a hostname under the cluster apps domain
#             (e.g. keycloak-keycloak.apps.mycluster.example.com).
#             The OKD router uses its own wildcard certificate.
#             No certificate files needed. Good for dev/testing.
#
#   edge      You provide a custom hostname and your own TLS certificate.
#             TLS terminates at the OKD router; plain HTTP to the pod.
#             Requires: KC_HOSTNAME, KC_TLS_CERT, KC_TLS_KEY
#
#   reencrypt You provide a custom hostname and certificates for both
#             the router-facing connection and the pod-internal connection.
#             TLS is maintained end-to-end all the way to the Keycloak pod.
#             Requires: KC_HOSTNAME, KC_TLS_CERT, KC_TLS_KEY,
#                       KC_TLS_CA_CERT (router's trust anchor for the pod cert)
#
KC_HOSTNAME_MODE=auto

# Custom hostname for Keycloak (required when mode is edge or reencrypt).
# Example: keycloak.mydomain.com
# Leave empty when mode is auto — the hostname is assigned by OKD at runtime.
KC_HOSTNAME=

# Paths to TLS certificate files on the machine running the install script.
# Required when KC_HOSTNAME_MODE is edge or reencrypt.
# The files are read at install time and stored as an OKD TLS secret.
#
#   KC_TLS_CERT  : path to the PEM-encoded certificate (fullchain recommended)
#   KC_TLS_KEY   : path to the PEM-encoded private key
#   KC_TLS_CA_CERT : path to the CA cert used to verify the pod's certificate
#                    (required only for reencrypt mode)
#
# Examples:
#   KC_TLS_CERT=/etc/ssl/certs/keycloak.crt
#   KC_TLS_KEY=/etc/ssl/private/keycloak.key
#   KC_TLS_CA_CERT=/etc/ssl/certs/ca.crt
KC_TLS_CERT=
KC_TLS_KEY=
KC_TLS_CA_CERT=


# ── Realm ────────────────────────────────────────────────────
KC_REALM=okd
KC_REALM_DISPLAY_NAME=OKD
KC_CLIENT_ID=okd
KC_IDP_NAME=keycloak

# Token lifespans (seconds).
KC_ACCESS_TOKEN_LIFESPAN=300       # 5 minutes
KC_SSO_SESSION_IDLE=1800           # 30 minutes
KC_SSO_SESSION_MAX=36000           # 10 hours


# ── OAuth ────────────────────────────────────────────────────
# claim  = map the 'sub' claim to an OKD identity (recommended)
# lookup = require pre-provisioned OKD users
KC_MAPPING_METHOD=claim

# Set to 'login' to always show the Keycloak login screen.
# Leave empty to allow SSO passthrough.
KC_PROMPT=login
